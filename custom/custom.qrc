<RCC>
    <qresource prefix="/custom/mavlink-actions">
        <file alias="DroneHub-flyview-actions.json">res/mavlink-actions/DroneHub-flyview-actions.json</file>
        <file alias="DroneHub-joystick-actions.json">res/mavlink-actions/DroneHub-joystick-actions.json</file>
    </qresource>

    <qresource prefix="/custom/img">
        <file alias="DroneHubLogo.svg">res/DroneHubLogo.svg</file>
        <file alias="logo.png">res/logo.png</file>
        <file alias="dhg-logo.png">res/dhg-logo.png</file>
        <file alias="dggcs-logo-original.png">res/dggcs-logo-original.png</file>
    </qresource>

    <!-- ქართული ფონტი — addApplicationFont(":/custom/fonts/NotoSansGeorgian.ttf") -->
    <qresource prefix="/custom/fonts">
        <file alias="NotoSansGeorgian.ttf">res/fonts/NotoSansGeorgian.ttf</file>
    </qresource>

    <!-- Custom.Theme singleton module. import path: "qrc:/Custom/imports" → import Custom -->
    <qresource prefix="/Custom/imports/Custom">
        <file alias="qmldir">res/Custom/qmldir</file>
        <file alias="Theme.qml">res/Custom/Theme.qml</file>
    </qresource>

    <!-- QML view overrides. CustomOverrideInterceptor გადაამისამართებს core URL-ებს:
         qrc:/qml/<path>  →  qrc:/Custom/qml/<path> (თუ აქ არსებობს). -->
    <qresource prefix="/Custom/qml">
        <file alias="QGroundControl/FlightDisplay/FlyViewCustomLayer.qml">res/Custom/qml/QGroundControl/FlightDisplay/FlyViewCustomLayer.qml</file>
        <file alias="QGroundControl/FlightDisplay/FlyViewWidgetLayer.qml">res/Custom/qml/QGroundControl/FlightDisplay/FlyViewWidgetLayer.qml</file>
        <file alias="QGroundControl/FlightDisplay/FlightDisplayViewVideo.qml">res/Custom/qml/QGroundControl/FlightDisplay/FlightDisplayViewVideo.qml</file>
        <file alias="QGroundControl/FlightDisplay/FlyViewToolStripActionList.qml">res/Custom/qml/QGroundControl/FlightDisplay/FlyViewToolStripActionList.qml</file>
        <file alias="QGroundControl/FlightDisplay/GuidedActionConfirm.qml">res/Custom/qml/QGroundControl/FlightDisplay/GuidedActionConfirm.qml</file>
        <file alias="QGroundControl/Controls/FlyViewToolBar.qml">res/Custom/qml/QGroundControl/Controls/FlyViewToolBar.qml</file>
        <file alias="QGroundControl/Controls/FlyViewToolBarIndicators.qml">res/Custom/qml/QGroundControl/Controls/FlyViewToolBarIndicators.qml</file>
        <file alias="QGroundControl/Toolbar/RCRSSIIndicator.qml">res/Custom/qml/QGroundControl/Toolbar/RCRSSIIndicator.qml</file>
        <file alias="QGroundControl/Controls/QGCPopupDialog.qml">res/Custom/qml/QGroundControl/Controls/QGCPopupDialog.qml</file>
        <file alias="QGroundControl/Controls/DropPanel.qml">res/Custom/qml/QGroundControl/Controls/DropPanel.qml</file>
        <file alias="QGroundControl/Controls/SettingsGroupLayout.qml">res/Custom/qml/QGroundControl/Controls/SettingsGroupLayout.qml</file>
        <file alias="QGroundControl/Controls/SliderSwitch.qml">res/Custom/qml/QGroundControl/Controls/SliderSwitch.qml</file>
        <file alias="QGroundControl/Controls/ToolStrip.qml">res/Custom/qml/QGroundControl/Controls/ToolStrip.qml</file>
        <file alias="QGroundControl/Controls/ToolStripHoverButton.qml">res/Custom/qml/QGroundControl/Controls/ToolStripHoverButton.qml</file>
        <file alias="QGroundControl/Controls/GPSIndicator.qml">res/Custom/qml/QGroundControl/Controls/GPSIndicator.qml</file>
        <file alias="QGroundControl/Controls/BatteryIndicator.qml">res/Custom/qml/QGroundControl/Controls/BatteryIndicator.qml</file>
        <file alias="QGroundControl/Controls/ToolStripDropPanel.qml">res/Custom/qml/QGroundControl/Controls/ToolStripDropPanel.qml</file>
        <file alias="QGroundControl/Controls/PlanViewToolBar.qml">res/Custom/qml/QGroundControl/Controls/PlanViewToolBar.qml</file>
        <file alias="QGroundControl/Controls/AppSettings.qml">res/Custom/qml/QGroundControl/Controls/AppSettings.qml</file>
        <file alias="QGroundControl/Controls/ToolIndicatorPage.qml">res/Custom/qml/QGroundControl/Controls/ToolIndicatorPage.qml</file>
        <file alias="QGroundControl/MainWindow/MainWindow.qml">res/Custom/qml/QGroundControl/MainWindow/MainWindow.qml</file>
    </qresource>
</RCC>
