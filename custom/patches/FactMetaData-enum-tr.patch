+namespace {
+QString _translateFactEnumString(const QString &source)
+{
+    return QCoreApplication::translate("FactEnum", source.toUtf8().constData());
+}
+
+QStringList _translateFactEnumStrings(const QStringList &sources)
+{
+    QStringList translated;
+    translated.reserve(sources.size());
+    for (const QString &source : sources) {
+        translated << _translateFactEnumString(source);
+    }
+    return translated;
+}
